###############################################################################
# Isaac Teleop 환경 변수 설정
#
# 사전 요구사항:
#   - NVIDIA GPU (RTX 3090+) + 드라이버 535+
#   - Docker 26.0+ / Docker Compose v2.25+
#   - NVIDIA Container Toolkit 1.17+ (1.13.x는 Vulkan 마운트 불가)
#   - Docker nvidia 런타임 등록 (sudo nvidia-ctk runtime configure --runtime=docker)
###############################################################################

# ── 이미지 버전 ─────────────────────────────────────────────────────────────
ISAAC_LAB_VERSION=2.3.0
ISAACTELEOP_VERSION=1.0.0

# ── CloudXR 설정 ────────────────────────────────────────────────────────────
# auto-webrtc  : Quest / Pico WebXR 클라이언트 (권장)
# Quest3       : Meta Quest 3 네이티브 클라이언트
# auto-native  : Apple Vision Pro
NV_DEVICE_PROFILE=auto-webrtc

# ── Meta Quest 3 핸드트래킹 ─────────────────────────────────────────────────
# false: 헤드셋 광학 핸드트래킹 (Quest 3 기본)
# true:  외부 Push 디바이스 (Manus 글러브 등)
NV_CXR_ENABLE_PUSH_DEVICES=false

# ── 호스트 사용자 ID (setup.sh가 자동 설정) ─────────────────────────────────
HOST_UID=1000
HOST_GID=1000

# ── 디스플레이 설정 (X11 포워딩) ─────────────────────────────────────────────
DISPLAY=:1

# ── 포트 설정 ───────────────────────────────────────────────────────────────
ISAAC_LAB_LIVESTREAM_PORT=8211
WEBXR_HTTP_PORT=8090
WEBXR_HTTPS_PORT=8453

# ── 텔레오퍼레이션 태스크 설정 ─────────────────────────────────────────────
# 실행 모드 (teleop: 단순 조작, record: 데이터 수집, 커스텀 스크립트 경로)
RUN_MODE=teleop

TELEOP_TASK=Isaac-PickPlace-GR1T2-Abs-v0
TELEOP_DEVICE=handtracking

# [데이터 수집 모드 전용]
NUM_DEMOS=10
DATASET_FILE=/workspace/user/datasets/dataset.hdf5

# ── CloudXR 네트워크 설정 ─────────────────────────────────────────────────────
# Quest 등 XR 디바이스가 접속할 서버 IP
# 비워두면 로컬 IP 자동 감지 (같은 LAN에서 사용 시)
# 외부 접속 시 공인 IP 설정 필요 (curl -s ifconfig.me)
CXR_PUBLIC_IP=

# STUN 서버 (NAT traversal 용, WebRTC ICE 후보 생성)
NV_CXR_WEBRTC_STUN_URL=stun:stun.l.google.com:19302
