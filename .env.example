###############################################################################
# Isaac Teleop 환경 변수 설정
#
# 사전 요구사항:
#   - NVIDIA GPU (RTX 3090+) + 드라이버 535+
#   - Docker 26.0+ / Docker Compose v2.25+
#   - NVIDIA Container Toolkit 1.17+ (1.13.x는 Vulkan 마운트 불가)
#   - Docker nvidia 런타임 등록 (sudo nvidia-ctk runtime configure --runtime=docker)
###############################################################################

# ── 이미지 버전 ─────────────────────────────────────────────────────────────
ISAAC_LAB_VERSION=2.3.0
ISAACTELEOP_VERSION=1.0.0

# ── CloudXR 설정 ────────────────────────────────────────────────────────────
# auto-webrtc  : Quest / Pico WebXR 클라이언트 (권장)
# Quest3       : Meta Quest 3 네이티브 클라이언트
# auto-native  : Apple Vision Pro
NV_DEVICE_PROFILE=auto-webrtc

# ── Meta Quest 3 핸드트래킹 ─────────────────────────────────────────────────
# false: 헤드셋 광학 핸드트래킹 (Quest 3 기본)
# true:  외부 Push 디바이스 (Manus 글러브 등)
NV_CXR_ENABLE_PUSH_DEVICES=false

# ── 호스트 사용자 ID (setup.sh가 자동 설정) ─────────────────────────────────
HOST_UID=1000
HOST_GID=1000

# ── XR / Start AR 자동화 ─────────────────────────────────────────────────────
# true : --headless + --xr → Isaac Sim UI 없이 AR(OpenXR) 세션 자동 시작
#        원격 PC에서 "Start AR" 클릭 불필요 (Quest는 WebXR에서 Connect만)
# false: X11/VNC로 Isaac Sim GUI 접속 후 AR 패널에서 Start AR 수동 클릭
XR_HEADLESS=true

# ── 디스플레이 설정 (X11 포워딩, XR_HEADLESS=false 일 때만 필요) ─────────────
DISPLAY=:1

# ── 포트 설정 ───────────────────────────────────────────────────────────────
ISAAC_LAB_LIVESTREAM_PORT=8211
WEBXR_HTTP_PORT=8090
WEBXR_HTTPS_PORT=8453

# ── 텔레오퍼레이션 태스크 설정 ─────────────────────────────────────────────
# 실행 모드 (teleop: 단순 조작, record: 데이터 수집, 커스텀 스크립트 경로)
RUN_MODE=teleop

TELEOP_TASK=Isaac-PickPlace-Locomanipulation-G1-Abs-v0
TELEOP_DEVICE=handtracking

# ── Custom asset 태스크 (FFW_SG2 + 서버랙 바코드 프레스) ─────────────────────
# TELEOP_TASK=Isaac-BarcodePress-FFW-SG2-Abs-v0
# RUN_MODE=teleop
# TELEOP_DEVICE=handtracking
# custom_assets/env/server_rack_v6.1/server_rack_teleop.usd
# custom_assets/robot/ai_worker/FFW_SG2.usd
# FFW record 시 양손 D405 RGB → HDF5 obs/left_hand_cam, obs/right_hand_cam
# AR Start 시 서버랙이 정면에 오도록 씬 Z 회전 (기본 +90°, 미세조정: SCENE_YAW_DEG=-90 등)
# SCENE_YAW_DEG=90
# HAND_CAM_WIDTH=256
# HAND_CAM_HEIGHT=160
# HAND_CAM_FOCAL_LENGTH=5.5
# 성공 조건: camera=오른손 cam 화면에 바코드(기본) | press=손가락 접촉(레거시)
# BARCODE_SUCCESS_MODE=camera
# BARCODE_CAM_MARGIN=0.15
# BARCODE_CAM_MIN_DEPTH=0.08
# BARCODE_CAM_MAX_DEPTH=2.5
# BARCODE_CAM_HOLD_TIME=2.0
# 텔레옵 전용 frustum (record/HDF5 hand_rgb 에 미포함, 기본 ON)
# HAND_CAM_FRUSTUM_VIS=1
# HAND_CAM_FRUSTUM_MAX_DEPTH=0.45
# Quest VR 시야 앞 3D 진행 HUD (CloudXR 스트림에 포함)
# BARCODE_XR_HUD=1
# BARCODE_XR_HUD_DISTANCE=0.55
# BARCODE_XR_HUD_DOWN=0.10

# [데이터 수집 모드 전용]
# G1 태스크(record) 시 torso d435 로봇 시점 RGB → HDF5 obs/robot_pov_cam
# ※ Quest VR은 머리(시선) 시점, robot_pov_cam은 가슴 고정 → 바구니가 안 보일 수 있음
#    아래 YAW/FOCAL 로 테이블 전체(휠+바구니)가 들어오게 조정 (isaac-lab 재시작 시 패치 반영)
# 해상도: Isaac Lab SDG 기본 256×160 (실제 D435 640×480이 아님). 필요 시 상향 예: 640 / 480
ROBOT_CAM_WIDTH=256
ROBOT_CAM_HEIGHT=160
ROBOT_CAM_YAW_DEG=-25
ROBOT_CAM_PITCH_DEG=10
ROBOT_CAM_FOCAL_LENGTH=5.5
# 1: record 시 HDF5 robot_pov_cam에 손 마커 미표시 (트래킹은 유지)
#    teleop 모드에서는 Quest/XR 붉은 점 피드백 유지
# 0: record 중에도 마커 표시
HIDE_HAND_MARKERS_IN_RECORD=1
NUM_DEMOS=10
DATASET_FILE=/workspace/user/datasets/dataset_g1_0519.hdf5

# ── CloudXR 네트워크 설정 ─────────────────────────────────────────────────────
# Quest 등 XR 디바이스가 접속할 서버 IP
# 비워두면 로컬 IP 자동 감지 (같은 LAN에서 사용 시)
# 외부 접속 시 공인 IP 설정 필요 (curl -s ifconfig.me)
CXR_PUBLIC_IP=

# STUN 서버 (NAT traversal 용, WebRTC ICE 후보 생성)
NV_CXR_WEBRTC_STUN_URL=stun:stun.l.google.com:19302
